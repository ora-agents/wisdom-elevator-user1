
page {

	background: #03174d;
}
.page {

	min-height: 100vh;

	position: relative;
}
.top-bg {

	position: absolute;

	left: 0;
	right: 0;
	top: 0;

	height: 100%;

	background:

	radial-gradient(
		circle at 50% 10%,
		rgba(0,213,255,0.75),
		transparent 34%
	),

	linear-gradient(
		145deg,
		#06134f 0%,
		#0b3aa0 48%,
		#03174d 100%
	);
}
.content {

	position: relative;

	z-index: 2;

	padding:
	80rpx 28rpx 120rpx;
}
.device-header {

	display: flex;
	align-items: center;
	justify-content: space-between;

	margin-bottom: 40rpx;
}
.device-name {

	font-size: 54rpx;
	font-weight: 900;

	color: #ffffff;
}
.device-location {

	font-size: 24rpx;

	color:
	rgba(255,255,255,0.72);

	margin-top: 12rpx;
}
.panel-card {

	background:
	rgba(255,255,255,0.12);

	border:
	1rpx solid rgba(255,255,255,0.14);

	-webkit-backdrop-filter: blur(20rpx);

	        backdrop-filter: blur(20rpx);

	border-radius: 40rpx;

	padding: 40rpx;

	text-align: center;
}
.temp-circle {

	width: 320rpx;
	height: 320rpx;

	border-radius: 50%;

	background: #ffffff;

	margin: 0 auto;

	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
}
.temp-num {

	font-size: 88rpx;
	font-weight: 900;

	color: #2563eb;
}
.temp-mode {

	font-size: 30rpx;

	color: #94a3b8;

	margin-top: 10rpx;
}
.temp-actions,
.floor-actions {

	display: flex;
	justify-content: center;

	margin-top: 40rpx;
}
.action-btn {

	width: 90rpx;
	height: 90rpx;

	border-radius: 50%;

	background: #ffffff;

	display: flex;
	align-items: center;
	justify-content: center;

	font-size: 42rpx;
	font-weight: 900;

	color: #2563eb;

	margin: 0 24rpx;
}
.big-icon {

	font-size: 120rpx;

	margin-top: 20rpx;
}
.panel-title {

	font-size: 36rpx;
	font-weight: 800;

	color: #ffffff;

	margin-top: 24rpx;
}
.light-value,
.lock-status,
.robot-status,
.floor-num {

	font-size: 68rpx;
	font-weight: 900;

	color: #ffffff;

	margin-top: 30rpx;
}
.tip-text,
.battery {

	font-size: 24rpx;

	color:
	rgba(255,255,255,0.72);

	margin-top: 16rpx;
}
.main-btn {

	height: 92rpx;

	border-radius: 24rpx;

	background:
	linear-gradient(
		135deg,
		#3b82f6,
		#2563eb
	);

	display: flex;
	align-items: center;
	justify-content: center;

	color: #ffffff;

	font-size: 30rpx;
	font-weight: 800;

	margin-top: 40rpx;
}
.action-row {

	display: flex;

	margin-top: 40rpx;
}
.bottom-btn {

	flex: 1;

	height: 92rpx;

	border-radius: 24rpx;

	display: flex;
	align-items: center;
	justify-content: center;

	color: #ffffff;

	font-size: 28rpx;
	font-weight: 800;
}
.orange {

	background:
	linear-gradient(
		135deg,
		#fb923c,
		#f97316
	);
}
.blue {

	background:
	linear-gradient(
		135deg,
		#3b82f6,
		#2563eb
	);

	margin-left: 20rpx;
}


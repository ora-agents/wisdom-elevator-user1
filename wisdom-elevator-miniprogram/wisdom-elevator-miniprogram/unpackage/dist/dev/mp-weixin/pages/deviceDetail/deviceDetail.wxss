
page{

	background:#F4F7FB;
}
.page{

	min-height:100vh;

	padding:
	90rpx
	28rpx
	40rpx;

	box-sizing:border-box;
}

/* 顶部 */
.title{

	font-size:44rpx;
	font-weight:800;

	color:#0F172A;
}
.subtitle{

	font-size:24rpx;

	color:#64748B;

	margin-top:12rpx;
	margin-bottom:34rpx;
}

/* 列表 */
.device-list{

	display:flex;
	flex-direction:column;
	gap:20rpx;
}
.device-card{

	background:white;

	border-radius:34rpx;

	padding:28rpx;

	display:flex;
	justify-content:space-between;
	align-items:center;

	box-shadow:
	0 10rpx 30rpx
	rgba(15,23,42,0.05);
}
.device-left{

	display:flex;
	align-items:center;
}
.device-icon{

	width:90rpx;
	height:90rpx;

	border-radius:26rpx;

	background:#EFF6FF;

	display:flex;
	align-items:center;
	justify-content:center;

	font-size:42rpx;

	margin-right:22rpx;
}
.device-name{

	font-size:30rpx;
	font-weight:800;

	color:#0F172A;
}
.device-info{

	font-size:23rpx;

	color:#64748B;

	margin-top:10rpx;
}
.device-status{

	display:flex;
	align-items:center;

	font-size:22rpx;

	color:#64748B;

	margin-top:12rpx;
}
.dot{

	width:14rpx;
	height:14rpx;

	border-radius:50%;

	margin-right:10rpx;
}
.online{

	background:#10B981;
}
.offline{

	background:#CBD5E1;
}
.device-right{

	display:flex;
	flex-direction:column;
	align-items:flex-end;
}
.temp{

	font-size:30rpx;
	font-weight:800;

	color:#2563EB;

	margin-bottom:16rpx;
}

/* 添加设备 */
.add-btn{

	height:96rpx;

	border-radius:28rpx;

	background:
	linear-gradient(
	135deg,
	#2563EB,
	#3B82F6
	);

	display:flex;
	align-items:center;
	justify-content:center;

	color:white;

	font-size:30rpx;
	font-weight:800;

	margin-top:34rpx;

	box-shadow:
	0 12rpx 30rpx
	rgba(37,99,235,0.25);
}


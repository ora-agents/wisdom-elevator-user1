
page{

	background:#F4F7FB;
}
.page{

	min-height:100vh;

	padding:
	90rpx
	28rpx
	40rpx;

	box-sizing:border-box;
}

/* 顶部 */
.title{

	font-size:44rpx;
	font-weight:800;

	color:#0F172A;
}
.subtitle{

	font-size:24rpx;

	color:#64748B;

	margin-top:12rpx;
	margin-bottom:34rpx;
}

/* section */
.section{

	margin-bottom:34rpx;
}
.section-title{

	font-size:32rpx;
	font-weight:800;

	color:#0F172A;

	margin-bottom:24rpx;
}

/* 添加方式 */
.method-grid{

	display:grid;

	grid-template-columns:
	repeat(2,1fr);

	gap:20rpx;
}
.method-card{

	height:220rpx;

	border-radius:34rpx;

	padding:28rpx;

	box-sizing:border-box;

	color:white;

	box-shadow:
	0 12rpx 40rpx
	rgba(15,23,42,0.08);
}
.method-icon{

	font-size:56rpx;
}
.method-name{

	font-size:30rpx;
	font-weight:800;

	margin-top:28rpx;
}
.method-desc{

	font-size:22rpx;

	margin-top:10rpx;

	opacity:0.9;
}
.blue{

	background:
	linear-gradient(
	135deg,
	#2563EB,
	#3B82F6
	);
}
.purple{

	background:
	linear-gradient(
	135deg,
	#7C3AED,
	#9333EA
	);
}
.orange{

	background:
	linear-gradient(
	135deg,
	#F97316,
	#FB923C
	);
}
.green{

	background:
	linear-gradient(
	135deg,
	#10B981,
	#34D399
	);
}

/* 设备列表 */
.device-list{

	display:flex;
	flex-direction:column;
	gap:20rpx;
}
.device-card{

	background:white;

	border-radius:30rpx;

	padding:28rpx;

	display:flex;
	justify-content:space-between;
	align-items:center;

	box-shadow:
	0 10rpx 30rpx
	rgba(15,23,42,0.05);
}
.device-left{

	display:flex;
	align-items:center;
}
.device-icon{

	width:88rpx;
	height:88rpx;

	border-radius:26rpx;

	background:#EFF6FF;

	display:flex;
	align-items:center;
	justify-content:center;

	font-size:42rpx;

	margin-right:20rpx;
}
.device-name{

	font-size:30rpx;
	font-weight:800;

	color:#0F172A;
}
.device-info{

	font-size:23rpx;

	color:#64748B;

	margin-top:10rpx;
}
.add-btn{

	width:120rpx;
	height:64rpx;

	border-radius:999rpx;

	background:#2563EB;

	display:flex;
	align-items:center;
	justify-content:center;

	color:white;

	font-size:24rpx;
	font-weight:700;
}


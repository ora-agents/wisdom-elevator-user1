<view class="page"><view class="top-bg"></view><view class="content"><view class="header"><view class="title"> 工单详情 </view><view class="subtitle"> 查看维修进度与处理状态 </view></view><view class="card"><view class="row"><view class="label"> 工单编号 </view><view class="value">{{a}}</view></view><view class="row"><view class="label"> 报修设备 </view><view class="value">{{b}}</view></view><view class="row"><view class="label"> 故障问题 </view><view class="value">{{c}}</view></view><view class="row"><view class="label"> 安装位置 </view><view class="value">{{d}}</view></view><view class="row"><view class="label"> 当前状态 </view><view class="status">{{e}}</view></view></view><view class="timeline-card"><view class="timeline-title"> 处理进度 </view><view class="timeline"><view wx:for="{{f}}" wx:for-item="item" wx:key="d" class="timeline-item"><view class="dot"></view><view wx:if="{{item.a}}" class="line"></view><view class="timeline-content"><view class="timeline-text">{{item.b}}</view><view class="timeline-time">{{item.c}}</view></view></view></view></view><view class="bottom-actions"><view class="action-btn blue" bindtap="{{g}}"> 联系维修员 </view><view class="action-btn orange" bindtap="{{h}}"> 确认完成 </view></view></view></view>

page {
	background: #03174d;
}
.page {
	min-height: 100vh;
	position: relative;
	overflow: hidden;
}

/* 顶部背景 */
.top-bg {

	position: absolute;

	left: 0;
	right: 0;
	top: 0;

	height: 520rpx;

	background:

	radial-gradient(
		circle at 50% 10%,
		rgba(0,213,255,0.7),
		transparent 34%
	),

	radial-gradient(
		circle at 90% 30%,
		rgba(59,130,246,0.6),
		transparent 32%
	),

	linear-gradient(
		145deg,
		#06134f 0%,
		#0b3aa0 48%,
		#03174d 100%
	);
}
.content {
	position: relative;
	z-index: 2;
	padding: 80rpx 28rpx 140rpx;
	box-sizing: border-box;
}

/* 用户卡片 */
.user-card {

	background:
	rgba(255,255,255,0.12);

	border:
	1rpx solid rgba(255,255,255,0.14);

	-webkit-backdrop-filter: blur(20rpx);

	        backdrop-filter: blur(20rpx);

	border-radius: 40rpx;

	padding: 34rpx;

	display: flex;
	align-items: center;
	justify-content: space-between;

	box-shadow:
	0 20rpx 60rpx rgba(0,0,0,0.18);
}
.login-box,
.user-info {

	display: flex;
	align-items: center;
}
.avatar {

	width: 110rpx;
	height: 110rpx;

	border-radius: 50%;

	background:
	linear-gradient(
		135deg,
		#3b82f6,
		#2563eb
	);

	display: flex;
	align-items: center;
	justify-content: center;

	font-size: 42rpx;
	font-weight: 800;

	color: #ffffff;

	box-shadow:
	0 10rpx 30rpx rgba(37,99,235,0.45);
}
.user-text,
.login-text {

	margin-left: 24rpx;
}
.username {

	font-size: 38rpx;
	font-weight: 900;

	color: #ffffff;
}
.phone {

	font-size: 24rpx;

	color:
	rgba(255,255,255,0.72);

	margin-top: 10rpx;
}
.edit-btn {

	height: 68rpx;

	padding:
	0 28rpx;

	border-radius: 999rpx;

	background:
	rgba(255,255,255,0.16);

	display: flex;
	align-items: center;
	justify-content: center;

	color: #ffffff;

	font-size: 24rpx;
	font-weight: 700;
}

/* 统计 */
.stats {

	display: grid;

	grid-template-columns:
	repeat(3,1fr);

	gap: 20rpx;

	margin-top: 36rpx;
}
.stat-item {

	height: 160rpx;

	border-radius: 34rpx;

	background:
	rgba(255,255,255,0.12);

	border:
	1rpx solid rgba(255,255,255,0.12);

	-webkit-backdrop-filter: blur(20rpx);

	        backdrop-filter: blur(20rpx);

	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
}
.stat-num {

	font-size: 50rpx;
	font-weight: 900;

	color: #ffffff;
}
.stat-label {

	font-size: 24rpx;

	margin-top: 12rpx;

	color:
	rgba(255,255,255,0.72);
}

/* 菜单 */
.menu {

	margin-top: 40rpx;
}
.menu-title {

	font-size: 38rpx;
	font-weight: 900;

	color: #ffffff;

	margin-bottom: 24rpx;
}
.menu-list {

	background:
	rgba(255,255,255,0.1);

	border:
	1rpx solid rgba(255,255,255,0.12);

	-webkit-backdrop-filter: blur(20rpx);

	        backdrop-filter: blur(20rpx);

	border-radius: 36rpx;

	overflow: hidden;
}
.menu-item {

	height: 110rpx;

	padding: 0 28rpx;

	display: flex;
	align-items: center;
	justify-content: space-between;

	border-bottom:
	1rpx solid rgba(255,255,255,0.08);

	transition: all 0.3s;
}
.menu-item:last-child {

	border-bottom: none;
}
.menu-item:active {

	background:
	rgba(255,255,255,0.06);
}
.menu-left {

	display: flex;
	align-items: center;

	color: #ffffff;

	font-size: 30rpx;
	font-weight: 600;
}
.menu-icon {

	width: 66rpx;
	height: 66rpx;

	border-radius: 20rpx;

	display: flex;
	align-items: center;
	justify-content: center;

	font-size: 30rpx;

	margin-right: 22rpx;
}

/* icon颜色 */
.blue {

	background:
	linear-gradient(
		135deg,
		#3b82f6,
		#2563eb
	);
}
.purple {

	background:
	linear-gradient(
		135deg,
		#a855f7,
		#7c3aed
	);
}
.orange {

	background:
	linear-gradient(
		135deg,
		#fb923c,
		#f97316
	);
}
.green {

	background:
	linear-gradient(
		135deg,
		#34d399,
		#10b981
	);
}
.cyan {

	background:
	linear-gradient(
		135deg,
		#06b6d4,
		#0891b2
	);
}
.red {

	background:
	linear-gradient(
		135deg,
		#ef4444,
		#dc2626
	);
}
.arrow {

	font-size: 38rpx;

	color:
	rgba(255,255,255,0.42);
}

/* 退出 */
.logout {

	color: #ef4444;
}


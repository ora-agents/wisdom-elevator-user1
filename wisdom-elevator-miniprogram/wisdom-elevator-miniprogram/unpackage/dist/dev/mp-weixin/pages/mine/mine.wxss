
page{

	background:#F8FAFC;
}
.page{

	padding:90rpx 28rpx;
}
.title{

	font-size:44rpx;
	font-weight:800;

	color:#0F172A;

	margin-bottom:30rpx;
}
.card{

	background:white;

	border-radius:32rpx;

	padding:30rpx;
}
.user{

	display:flex;
	align-items:center;
}
.avatar{

	width:100rpx;
	height:100rpx;

	border-radius:50%;

	background:#2563EB;

	display:flex;
	align-items:center;
	justify-content:center;

	font-size:48rpx;

	color:white;

	margin-right:24rpx;
}
.name{

	font-size:32rpx;
	font-weight:700;

	color:#0F172A;
}
.phone{

	font-size:24rpx;

	color:#64748B;

	margin-top:10rpx;
}


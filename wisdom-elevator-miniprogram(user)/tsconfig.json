{
  "compilerOptions": {
  "target": "ES2017",
  "module": "commonjs",
  "lib": ["ES2017", "DOM"],
  "allowJs": true,
  "skipLibCheck": true,
  "strict": false,
  "forceConsistentCasingInFileNames": true,
  "noEmit": true,
  "resolveJsonModule": true,
  "esModuleInterop": true,
  "baseUrl": ".",
  "paths": {
  "@/*": ["*"]
  }
  },
  "include": ["**/*.ts", "**/*.d.ts"],
  "exclude": ["node_modules"]
  }
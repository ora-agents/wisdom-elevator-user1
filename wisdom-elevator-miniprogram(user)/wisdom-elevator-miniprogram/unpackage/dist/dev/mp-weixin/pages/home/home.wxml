<view class="page"><view class="top-bg"></view><view class="content"><view class="topbar"><view><view class="family-name">智享家AI管家</view><view class="welcome">欢迎回家，生活因智能而美好</view></view><view class="top-icons"><view class="icon-btn">•••</view><view class="icon-btn">◎</view></view></view><view class="weather-card"><view class="weather-left"><view class="weather-icon">☀️</view><view><view class="temp">26℃</view><view class="weather-desc">多云 ｜ 空气优</view></view></view><view class="weather-right"><view class="weather-item"><view class="weather-value">58%</view><view class="weather-label">湿度</view></view><view class="weather-item"><view class="weather-value">25℃</view><view class="weather-label">室内温度</view></view></view></view><view class="lift-panel"><view class="lift-item alarm" bindtap="{{a}}"><view class="lift-icon">🚨</view><view class="lift-text">报警</view></view><view class="lift-item" bindtap="{{b}}"><view class="lift-icon">🛠</view><view class="lift-text">设备报修</view></view><view class="lift-item" bindtap="{{c}}"><view class="lift-icon">🧰</view><view class="lift-text">设备保养</view></view><view class="lift-item" bindtap="{{d}}"><view class="lift-icon">📷</view><view class="lift-text">扫码绑定</view></view></view><view class="section-title">常用设备</view><view wx:if="{{e}}" class="empty-box"><view class="empty-icon">📦</view><view class="empty-text">暂无设备</view></view><view wx:else class="lift-list"><view wx:for="{{f}}" wx:for-item="item" wx:key="c" class="lift-card" bindtap="{{item.d}}"><view class="lift-card-icon">🛗</view><view class="lift-info"><view class="lift-name">{{item.a}}</view><view class="lift-model">{{item.b}}</view></view></view></view><view class="section-title">我的工单</view><view class="order-panel"><view class="order-item" bindtap="{{g}}"><view class="order-icon red">🚨</view><view class="order-text">救援记录</view></view><view class="order-item" bindtap="{{h}}"><view class="order-icon orange">⚙️</view><view class="order-text">维修记录</view></view><view class="order-item" bindtap="{{i}}"><view class="order-icon blue">✔️</view><view class="order-text">保养记录</view></view></view><view class="section-title stats-title"> 设备总览 </view><view class="stats-grid"><view class="stats-card"><view class="stats-num">{{j}}</view><view class="stats-label"> 全部设备 </view></view><view class="stats-card"><view class="stats-num green">{{k}}</view><view class="stats-label"> 在线设备 </view></view><view class="stats-card"><view class="stats-num gray">{{l}}</view><view class="stats-label"> 离线设备 </view></view><view class="stats-card"><view class="stats-num red">{{m}}</view><view class="stats-label"> 告警设备 </view></view></view><view class="section-header"><view class="section-title"> 全部设备 </view><view class="more-btn"> 查看全部 › </view></view><scroll-view scroll-x="true" class="device-room-scroll" show-scrollbar="false"><view class="device-room-row"><view wx:for="{{n}}" wx:for-item="item" wx:key="c" class="{{['device-room-item', item.b]}}" bindtap="{{item.d}}">{{item.a}}</view></view></scroll-view><view class="device-grid"><view wx:for="{{o}}" wx:for-item="item" wx:key="i" class="device-card" bindtap="{{item.j}}"><view class="device-top"><view class="device-icon">{{item.a}}</view><view class="{{['device-status', item.c]}}">{{item.b}}</view></view><view class="device-name">{{item.d}}</view><view class="device-desc">{{item.e}}</view><view class="device-bottom"><view class="room-tag">{{item.f}}</view><view class="{{['power-btn', item.g]}}" catchtap="{{item.h}}"> ⏻ </view></view></view></view></view><view class="voice-float" bindtap="{{p}}"><view class="voice-circle"> 🎤 </view></view><view wx:if="{{q}}" class="dialog-mask"><view class="bind-dialog"><view class="dialog-title"> 添加电梯设备 </view><input class="lift-input" placeholder="请输入电梯编号" value="{{r}}" bindinput="{{s}}"/><view class="dialog-actions"><view class="scan-btn" bindtap="{{t}}"> 扫码识别 </view><view class="submit-btn" bindtap="{{v}}"> 确认绑定 </view></view><view class="close-dialog" bindtap="{{w}}"> 取消 </view></view></view></view>
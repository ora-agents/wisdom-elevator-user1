<view class="page"><view class="top-bg"></view><view class="content"><view class="header"><view><view class="title"> 我的设备 </view><view class="subtitle"> 家庭智能设备控制中心 </view></view><view class="add-btn" bindtap="{{a}}"> ＋ </view></view><view class="search-box"><view class="search-icon"> 🔍 </view><input class="search-input" placeholder="搜索设备名称" value="{{b}}" bindinput="{{c}}"/></view><view class="stats-wrap"><view class="stats-card"><view class="stats-num">{{d}}</view><view class="stats-label"> 全部设备 </view></view><view class="stats-card"><view class="stats-num green">{{e}}</view><view class="stats-label"> 在线设备 </view></view><view class="stats-card"><view class="stats-num orange">{{f}}</view><view class="stats-label"> 离线设备 </view></view></view><view class="section-title"> 设备分类 </view><view class="device-grid"><view wx:for="{{g}}" wx:for-item="item" wx:key="f" class="device-card" bindtap="{{item.g}}"><view class="device-top"><view class="device-icon" style="{{'background:' + item.b}}">{{item.a}}</view><view class="device-count">{{item.c}}</view></view><view class="device-name">{{item.d}}</view><view class="device-desc">{{item.e}}</view></view></view><view class="section-title"> 全部设备 </view><view class="real-device-list"><view wx:for="{{h}}" wx:for-item="item" wx:key="j" class="real-device-card" bindtap="{{item.k}}"><view class="real-left"><view class="real-icon" style="{{'background:' + item.b}}">{{item.a}}</view><view><view class="real-name">{{item.c}}</view><view class="real-desc">{{item.d}} · {{item.e}}</view></view></view><view class="real-right"><view class="{{['status-tag', item.g]}}">{{item.f}}</view><switch checked="{{item.h}}" color="#2563eb" scale="0.7" catchtap="{{item.i}}"/></view></view></view></view></view>
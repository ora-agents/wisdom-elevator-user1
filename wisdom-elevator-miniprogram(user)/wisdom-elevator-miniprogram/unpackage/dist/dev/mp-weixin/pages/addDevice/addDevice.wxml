<view class="page"><view class="header"><view class="title"> 添加设备 </view><view class="subtitle"> 连接新的智能设备 </view></view><view class="section"><view class="section-title"> 添加方式 </view><view class="method-grid"><view class="method-card blue" bindtap="{{a}}"><view class="method-icon"> 📷 </view><view class="method-name"> 扫码添加 </view><view class="method-desc"> 扫描设备二维码 </view></view><view class="method-card purple" bindtap="{{b}}"><view class="method-icon"> 📶 </view><view class="method-name"> 蓝牙连接 </view><view class="method-desc"> 发现附近设备 </view></view><view class="method-card orange" bindtap="{{c}}"><view class="method-icon"> 🌐 </view><view class="method-name"> 局域网搜索 </view><view class="method-desc"> 自动搜索设备 </view></view><view class="method-card green" bindtap="{{d}}"><view class="method-icon"> ⌨️ </view><view class="method-name"> 手动输入 </view><view class="method-desc"> 输入设备ID </view></view></view></view><view class="section"><view class="section-title"> 附近发现设备 </view><view class="device-list"><view wx:for="{{e}}" wx:for-item="item" wx:key="e" class="device-card"><view class="device-left"><view class="device-icon">{{item.a}}</view><view><view class="device-name">{{item.b}}</view><view class="device-info">{{item.c}}</view></view></view><view class="add-btn" bindtap="{{item.d}}"> 添加 </view></view></view></view></view>